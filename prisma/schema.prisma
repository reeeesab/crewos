generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  clerkId        String          @unique
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  products       ProductMember[]
  assignedIssues Issue[]         @relation("AssignedIssues")
  points         UserPoints[]
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  status             ProductStatus       @default(BETA)
  type               String?
  website            String?
  mrr                Float               @default(0)
  arr                Float               @default(0)
  activeUsers        Int                 @default(0)
  activeSubscriptions Int                @default(0)
  churnRate          Float               @default(0)
  netMargin          Float               @default(0)
  openBugs           Int                 @default(0)
  healthScore        Int                 @default(0)
  inviteCodeHash     String?             @unique
  inviteCodeHint     String?
  inviteCodeUpdatedAt DateTime?
  newMrr             Float               @default(0)
  churnedMrr         Float               @default(0)
  lastChangelogAt    DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  members            ProductMember[]
  integration        IntegrationConfig?
  issues             Issue[]
  costs              Cost[]
  socialAccounts     SocialAccount[]
  changelogs         Changelog[]
  snapshots          RevenueSnapshot[]
  buildInPublicPosts BuildInPublicPost[]
  analyticsConfig    AnalyticsConfig?
  analyticsSnapshots AnalyticsSnapshot[]
  dunningAttempts    DunningAttempt[]
  notificationPreference NotificationPreference?
  notificationEvents  NotificationEvent[]
  webhookEvents       WebhookEvent[]
  userPoints          UserPoints[]
}

enum ProductStatus {
  LIVE
  BETA
  ARCHIVED
}

model ProductMember {
  id          String     @id @default(cuid())
  userId      String
  productId   String
  role        MemberRole @default(VIEWER)
  permissions Json
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum RevenueProvider {
  STRIPE
  DODO_PAYMENTS
}

model IntegrationConfig {
  id              String          @id @default(cuid())
  productId       String          @unique
  provider        RevenueProvider @default(STRIPE)

  // Stripe
  stripeAccountId String?
  stripeApiKey    String?

  // DodoPayment
  dodoApiKey      String?

  // Webhooks + Dunning
  stripeWebhookSecret String?
  dodoWebhookSecret   String?
  dunningEnabled      Boolean   @default(false)
  dunningFromEmail    String?
  dunningSenderName   String?
  dunningReplyTo      String?
  dunningEmail1Subject String?
  dunningEmail1Body    String? @db.Text
  dunningEmail2Subject String?
  dunningEmail2Body    String? @db.Text
  dunningEmail3Subject String?
  dunningEmail3Body    String? @db.Text

  lastSyncedAt    DateTime?
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RevenueSnapshot {
  id                  String   @id @default(cuid())
  productId           String
  mrr                 Float
  arr                 Float
  users               Int
  activeSubscriptions Int      @default(0)
  newMrr              Float    @default(0)
  churnedMrr          Float    @default(0)
  churn               Float
  date                DateTime @default(now())
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Issue {
  id          String        @id @default(cuid())
  productId   String
  type        IssueType
  title       String
  description String?
  priority    IssuePriority @default(LOW)
  status      IssueStatus   @default(OPEN)
  dueDate     DateTime?
  milestone   String?
  reporterId  String?
  assigneeId  String?
  points      Int           @default(0)
  createdAt   DateTime      @default(now())
  closedAt    DateTime?
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  assignee    User?         @relation("AssignedIssues", fields: [assigneeId], references: [id])
  costs       Cost[]
}

enum IssueType {
  FEATURE
  BUG
  MARKETING
  OTHER
}

enum IssuePriority {
  P0
  P1
  P2
  HIGH
  MEDIUM
  LOW
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum CostSource {
  MANUAL
  API_STRIPE
  API_DODO
}

model Cost {
  id           String       @id @default(cuid())
  productId    String
  name         String
  category     CostCategory
  amount       Float
  budget       Float?
  billingCycle String       @default("monthly")
  vendor       String?
  month        String       @default("")
  source       CostSource   @default(MANUAL)
  issueId      String?
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  issue        Issue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
}

enum CostCategory {
  LLM
  CLOUD
  PAYMENTS
  EMAIL
  TOOLING
  OTHER
}

model SocialAccount {
  id           String    @id @default(cuid())
  productId    String
  platform     String
  handle       String
  accessToken  String?
  followers    Int       @default(0)
  engagement   Float     @default(0)
  impressions  Int       @default(0)
  lastSyncedAt DateTime?
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Changelog {
  id            String          @id @default(cuid())
  productId     String
  title         String
  body          String
  type          ChangelogType
  status        ChangelogStatus @default(DRAFT)
  sourceIssueId String?
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum ChangelogType {
  SHIPPED
  BUGFIX
  IMPROVEMENT
}

enum ChangelogStatus {
  DRAFT
  PUBLISHED
}

model BuildInPublicPost {
  id          String    @id @default(cuid())
  productId   String
  platform    String
  draftText   String
  status      String    @default("draft")
  sourceType  String
  sourceId    String?
  scheduledAt DateTime?
  postedAt    DateTime?
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AnalyticsConfig {
  id           String   @id @default(cuid())
  productId    String   @unique
  propertyId   String
  clientEmail  String
  privateKey   String   @db.Text
  isConnected  Boolean  @default(false)
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AnalyticsSnapshot {
  id                String   @id @default(cuid())
  productId         String
  date              DateTime @default(now())
  totalSessions     Int      @default(0)
  totalUsers        Int      @default(0)
  newUsers          Int      @default(0)
  returningUsers    Int      @default(0)
  avgEngagementTime Float    @default(0)
  bounceRate        Float    @default(0)
  pageViews         Int      @default(0)
  signupEvents      Int      @default(0)
  conversionRate    Float    @default(0)
  topSources        Json     @default("[]")
  topPages          Json     @default("[]")
  topCountries      Json     @default("[]")
  aiSummary         String?  @db.Text
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, date])
}

enum DunningStatus {
  FAILED
  RECOVERED
  CLOSED
}

model DunningAttempt {
  id                String         @id @default(cuid())
  productId         String
  provider          RevenueProvider
  providerInvoiceId String
  customerId        String?
  customerEmail     String
  customerName      String?
  amountCents       Int
  currency          String         @default("USD")
  paymentUrl        String?
  failedCount       Int            @default(1)
  emailsSent        Int            @default(0)
  status            DunningStatus  @default(FAILED)
  firstFailedAt     DateTime       @default(now())
  lastFailedAt      DateTime       @default(now())
  lastEmailSentAt   DateTime?
  recoveredAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, provider, providerInvoiceId])
  @@index([productId, status, updatedAt])
}

model NotificationPreference {
  id                     String   @id @default(cuid())
  productId              String   @unique
  paymentFailedEnabled   Boolean  @default(true)
  healthScoreEnabled     Boolean  @default(true)
  healthScoreThreshold   Int      @default(60)
  trafficSpikeEnabled    Boolean  @default(true)
  issueOverdueEnabled    Boolean  @default(true)
  weeklyDigestEnabled    Boolean  @default(true)
  weeklyDigestDay        Int      @default(1)
  weeklyDigestTime       String   @default("08:00")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model NotificationEvent {
  id         String   @id @default(cuid())
  productId  String
  type       String
  title      String
  message    String?
  severity   String   @default("info")
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  productId  String
  provider   RevenueProvider
  eventType  String
  status     String   @default("received")
  message    String?
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, provider, createdAt])
}

model UserPoints {
  id        String   @id @default(cuid())
  userId    String
  productId String
  points    Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

